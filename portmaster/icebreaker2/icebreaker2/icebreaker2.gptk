# Icebreaker 2 gptokeyb config
# The game uses SDL_GameController natively, so we disable all key emulation
# and keep gptokeyb only for the standard PortMaster Select+Start force-quit
# chord (handled by the runtime, not via this file's mappings).

back = esc
guide = esc

a = disabled
b = disabled
x = disabled
y = disabled
l1 = disabled
r1 = disabled
l2 = disabled
r2 = disabled
l3 = disabled
r3 = disabled
start = disabled
up = disabled
down = disabled
left = disabled
right = disabled

left_analog_up = disabled
left_analog_down = disabled
left_analog_left = disabled
left_analog_right = disabled
right_analog_up = disabled
right_analog_down = disabled
right_analog_left = disabled
right_analog_right = disabled

hotkey = select
hotkey_combo = start
